{
   "name": "uptime-monitoring-service",
   "type": "module",
   "scripts": {
      "dev": "tsx watch src/index.ts",
      "build": "tsc",
      "start": "node dist/src/index.js",
      "migrate:deploy": "prisma migrate deploy --config=./prisma/prisma.config.ts",
      "pm2:start": "pm2 start ecosystem.config.cjs --update-env",
      "pm2:reload": "pm2 reload uptime-api --update-env",
      "generate": "npx prisma generate",
      "migrate": "npx prisma migrate dev --config=./prisma/prisma.config.ts",
      "studio": "npx prisma studio --config=./prisma/prisma.config.ts"
   },
   "dependencies": {
      "@hono/node-server": "^1.19.11",
      "@hono/standard-validator": "^0.2.2",
      "@prisma/adapter-better-sqlite3": "^7.0.1",
      "@prisma/client": "^7.0.1",
      "croner": "^9.1.0",
      "dotenv": "^17.2.3",
      "hono": "^4.12.7",
      "hono-rate-limiter": "^0.5.3",
      "nodemailer": "^7.0.11",
      "ping": "^0.4.4",
      "valibot": "^1.2.0"
   },
   "devDependencies": {
      "@types/node": "^20.11.17",
      "@types/nodemailer": "^7.0.4",
      "@types/ping": "^0.4.4",
      "prisma": "^7.0.1",
      "tsx": "^4.7.1",
      "typescript": "^5.8.3"
   }
}
